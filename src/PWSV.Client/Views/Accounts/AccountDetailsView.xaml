<UserControl x:Class="PWSV.Client.Views.Accounts.AccountDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PWSV.Client.Converters">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:MoneyFormatConverter x:Key="MoneyFmt" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,16" LastChildFill="True">
            <Button DockPanel.Dock="Right" Content="← Назад"
                    Command="{Binding BackCommand}"
                    Style="{StaticResource GhostButtonStyle}"
                    VerticalAlignment="Top" />
            <StackPanel>
                <TextBlock Text="Деталі рахунку" Style="{StaticResource HeadingTextStyle}" />
                <TextBlock Text="Перегляд інформації та історії транзакцій"
                           Style="{StaticResource SubtitleTextStyle}" />
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1" Style="{StaticResource ErrorBannerStyle}"
                Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{StaticResource ErrorHoverBrush}"
                       TextWrapping="Wrap" />
        </Border>

        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}"
                    Margin="0,0,8,0">
                <StackPanel DataContext="{Binding Account}">
                    <TextBlock Text="{Binding Name}"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,12" />

                    <WrapPanel Margin="0,0,0,16">
                        <Border Background="{StaticResource PrimarySoftBrush}"
                                CornerRadius="6" Padding="10,4" Margin="0,0,8,0">
                            <TextBlock Text="{Binding AccountTypeName}"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       FontSize="12" FontWeight="SemiBold" />
                        </Border>
                        <Border Background="{StaticResource AccentSoftBrush}"
                                CornerRadius="6" Padding="10,4" Margin="0,0,8,0">
                            <TextBlock Text="{Binding CurrencyCode}"
                                       Foreground="{StaticResource AccentHoverBrush}"
                                       FontSize="12" FontWeight="SemiBold" />
                        </Border>
                    </WrapPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Номер рахунку"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding AccountNumber}"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Статус"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4" />
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{Binding IsActive, Converter={StaticResource BoolToYesNo}}"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}"
                    Background="{StaticResource PrimarySoftBrush}"
                    Margin="8,0,0,0">
                <StackPanel VerticalAlignment="Center" DataContext="{Binding Account}">
                    <TextBlock Text="ПОТОЧНИЙ БАЛАНС"
                               Foreground="{StaticResource PrimaryBrush}"
                               FontSize="11" FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <TextBlock Text="{Binding Balance, Converter={StaticResource MoneyFmt}}"
                               Foreground="{StaticResource PrimaryHoverBrush}"
                               FontSize="28" FontWeight="Bold" />
                    <TextBlock Text="{Binding CurrencyCode}"
                               Foreground="{StaticResource PrimaryBrush}"
                               FontSize="12" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="3" Style="{StaticResource CardBorderStyle}" Padding="0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="16,12"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <TextBlock Text="Останні транзакції (до 50)"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                </Border>
                <DataGrid ItemsSource="{Binding RecentTransactions}" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ДАТА" Binding="{Binding OccurredAt, StringFormat=\{0:yyyy-MM-dd HH:mm\}}" Width="160" />
                        <DataGridTextColumn Header="ТИП" Binding="{Binding Kind, Converter={StaticResource TxKind}}" Width="100" />
                        <DataGridTextColumn Header="КАТЕГОРІЯ" Binding="{Binding CategoryName}" Width="*" />
                        <DataGridTextColumn Header="СУМА" Binding="{Binding Amount, Converter={StaticResource MoneyFmt}}" Width="140">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Setter Property="HorizontalAlignment" Value="Right" />
                                    <Setter Property="Margin" Value="0,0,12,0" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="ОПИС" Binding="{Binding Description}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
