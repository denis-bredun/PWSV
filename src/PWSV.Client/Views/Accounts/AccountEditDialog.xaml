<Window x:Class="PWSV.Client.Views.Accounts.AccountEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:PWSV.Client.Converters"
        Title="Рахунок" Width="480" Height="640"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <Border Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="Дані рахунку" Style="{StaticResource HeadingTextStyle}" />
                <TextBlock Text="Заповніть інформацію про рахунок"
                           Style="{StaticResource SubtitleTextStyle}" />
            </StackPanel>

            <Border Grid.Row="1" Style="{StaticResource ErrorBannerStyle}"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource ErrorHoverBrush}"
                           TextWrapping="Wrap" />
            </Border>

            <StackPanel Grid.Row="2">
                <TextBlock Text="Назва" Style="{StaticResource LabelTextStyle}" />
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" TabIndex="0" />

                <TextBlock Text="Тип рахунку" Style="{StaticResource LabelTextStyle}" />
                <ComboBox ItemsSource="{Binding AccountTypes}"
                          SelectedItem="{Binding SelectedAccountType}"
                          DisplayMemberPath="DisplayName"
                          IsEnabled="{Binding IsCreating}" TabIndex="1" />

                <TextBlock Text="Валюта" Style="{StaticResource LabelTextStyle}" />
                <ComboBox ItemsSource="{Binding Currencies}"
                          SelectedItem="{Binding SelectedCurrency}"
                          DisplayMemberPath="Code"
                          IsEnabled="{Binding IsCreating}" TabIndex="2" />

                <TextBlock Text="Номер рахунку (опціонально, шифрується)"
                           Style="{StaticResource LabelTextStyle}" />
                <TextBox Text="{Binding AccountNumber, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" TabIndex="3" />

                <StackPanel Visibility="{Binding IsCreating, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Початковий баланс" Style="{StaticResource LabelTextStyle}" />
                    <TextBox Text="{Binding InitialBalanceInput, UpdateSourceTrigger=PropertyChanged}" TabIndex="4" />
                </StackPanel>

                <CheckBox Content="Активний" IsChecked="{Binding IsActive}"
                          Margin="0,16,0,0" TabIndex="5"
                          Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}" />
            </StackPanel>

            <Border Grid.Row="3" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0" Margin="0,16,0,0" Padding="0,16,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Скасувати" Click="OnCancelClick"
                            Style="{StaticResource SecondaryButtonStyle}" TabIndex="7" />
                    <Button Content="Зберегти" Command="{Binding SaveCommand}"
                            IsDefault="True" TabIndex="6" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
