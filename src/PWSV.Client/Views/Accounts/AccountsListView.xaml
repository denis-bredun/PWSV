<UserControl x:Class="PWSV.Client.Views.Accounts.AccountsListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PWSV.Client.Converters">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:MoneyFormatConverter x:Key="MoneyFmt" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Рахунки" Style="{StaticResource HeadingTextStyle}" />
            <TextBlock Text="Управління вашими грошовими рахунками" Style="{StaticResource SubtitleTextStyle}" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource ToolbarBorderStyle}">
            <StackPanel Orientation="Horizontal">
                <Button Content="+ Додати рахунок" Command="{Binding AddCommand}" />
                <Button Content="Редагувати" Command="{Binding EditCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                <Button Content="Деталі" Command="{Binding ViewDetailsCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                <Button Content="Деактивувати" Command="{Binding DeactivateCommand}" Style="{StaticResource DangerButtonStyle}" />
                <Button Content="↻ Оновити" Command="{Binding LoadCommand}" Style="{StaticResource GhostButtonStyle}" />
                <Border Width="1" Background="{StaticResource BorderBrush}" Margin="8,4" />
                <CheckBox Content="Показувати неактивні" IsChecked="{Binding IncludeInactive}"
                          VerticalAlignment="Center" Margin="8,0,0,0" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource ErrorBannerStyle}"
                Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorHoverBrush}" TextWrapping="Wrap" />
        </Border>

        <Border Grid.Row="3" Style="{StaticResource CardBorderStyle}" Padding="0">
            <DataGrid ItemsSource="{Binding Accounts}" SelectedItem="{Binding SelectedAccount}"
                      BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="НАЗВА" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Header="ТИП" Binding="{Binding AccountTypeName}" Width="180" />
                    <DataGridTextColumn Header="ВАЛЮТА" Binding="{Binding CurrencyCode}" Width="100" />
                    <DataGridTextColumn Header="БАЛАНС" Binding="{Binding Balance, Converter={StaticResource MoneyFmt}}" Width="160">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="HorizontalAlignment" Value="Right" />
                                <Setter Property="Margin" Value="0,0,12,0" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridCheckBoxColumn Header="АКТИВНИЙ" Binding="{Binding IsActive}" Width="100" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
