<UserControl x:Class="PWSV.Client.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PWSV.Client.Converters">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Border Style="{StaticResource CardBorderStyle}"
                Width="420" Padding="32,32,32,28"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Effect="{StaticResource ShadowLarge}">
            <StackPanel>
                <Border Width="56" Height="56"
                        Background="{StaticResource PrimarySoftBrush}"
                        CornerRadius="14"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,16">
                    <TextBlock Text="₴" FontSize="32" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>

                <TextBlock Text="Ласкаво просимо"
                           Style="{StaticResource HeadingTextStyle}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Вхід до Personal Wealth &amp; Security Vault"
                           Style="{StaticResource SubtitleTextStyle}"
                           HorizontalAlignment="Center" />

                <Border Style="{StaticResource ErrorBannerStyle}"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource ErrorHoverBrush}"
                               TextWrapping="Wrap" />
                </Border>

                <TextBlock Text="Ім'я користувача" Style="{StaticResource LabelTextStyle}" />
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" TabIndex="0" />

                <TextBlock Text="Пароль" Style="{StaticResource LabelTextStyle}" />
                <PasswordBox x:Name="PasswordBox" PasswordChar="•" TabIndex="1"
                             PasswordChanged="PasswordBox_OnPasswordChanged" />

                <TextBlock Text="Мастер-пароль (для розшифрування даних)"
                           Style="{StaticResource LabelTextStyle}" />
                <PasswordBox x:Name="MasterPasswordBox" PasswordChar="•" TabIndex="2"
                             PasswordChanged="MasterPasswordBox_OnPasswordChanged" />

                <Grid Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Зареєструватись"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding GoToRegisterCommand}"
                            Margin="0,0,4,0" TabIndex="4" />
                    <Button Grid.Column="1" Content="Увійти"
                            Command="{Binding LoginCommand}" IsDefault="True"
                            Margin="4,0,0,0" TabIndex="3" />
                </Grid>

                <TextBlock Text="Зачекайте..."
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0"
                           Style="{StaticResource MutedTextStyle}"
                           Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
