<UserControl x:Class="PWSV.Client.Views.Currencies.CurrenciesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PWSV.Client.Converters">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Валюти" Style="{StaticResource HeadingTextStyle}" />
            <TextBlock Text="Довідник підтримуваних валют"
                       Style="{StaticResource SubtitleTextStyle}" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource ErrorBannerStyle}"
                Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{StaticResource ErrorHoverBrush}"
                       TextWrapping="Wrap" />
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" Padding="16" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Додати нову валюту" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="0,0,0,12" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Код" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" Margin="0,0,6,0" />
                    <TextBox Grid.Column="1" Width="80" Margin="0,0,12,0"
                             VerticalAlignment="Center"
                             Text="{Binding NewCode, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />
                    <TextBlock Grid.Column="2" Text="Назва" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" Margin="0,0,6,0" />
                    <TextBox Grid.Column="3" Margin="0,0,12,0" HorizontalAlignment="Stretch"
                             VerticalAlignment="Center"
                             Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />
                    <TextBlock Grid.Column="4" Text="Символ" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" Margin="0,0,6,0" />
                    <TextBox Grid.Column="5" Width="90" Margin="0,0,12,0"
                             VerticalAlignment="Center"
                             Text="{Binding NewSymbol, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />
                    <TextBlock Grid.Column="6" Text="Знаків" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" Margin="0,0,6,0" />
                    <TextBox Grid.Column="7" Width="70" Margin="0,0,16,0"
                             VerticalAlignment="Center"
                             Text="{Binding NewDecimalPlaces, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="8" Content="+ Додати" Command="{Binding AddCommand}" />
                    <Button Grid.Column="9" Content="↻ Оновити" Command="{Binding LoadCommand}"
                            Style="{StaticResource GhostButtonStyle}" />
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource CardBorderStyle}" Padding="0">
            <DataGrid ItemsSource="{Binding Currencies}" BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="КОД" Binding="{Binding Code}" Width="100" />
                    <DataGridTextColumn Header="НАЗВА" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Header="СИМВОЛ" Binding="{Binding Symbol}" Width="100" />
                    <DataGridTextColumn Header="ЗНАКІВ ПІСЛЯ КОМИ" Binding="{Binding DecimalPlaces}" Width="180" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
