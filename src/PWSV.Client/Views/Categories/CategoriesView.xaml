<UserControl x:Class="PWSV.Client.Views.Categories.CategoriesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PWSV.Client.Converters">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Категорії" Style="{StaticResource HeadingTextStyle}" />
            <TextBlock Text="Класифікація доходів та витрат у дереві категорій"
                       Style="{StaticResource SubtitleTextStyle}" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource ToolbarBorderStyle}">
            <StackPanel Orientation="Horizontal">
                <Button Content="+ Дохідну" Command="{Binding AddIncomeCommand}" />
                <Button Content="+ Витратну" Command="{Binding AddExpenseCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" />
                <Button Content="Редагувати" Command="{Binding EditCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" />
                <Button Content="Деактивувати" Command="{Binding DeactivateCommand}"
                        Style="{StaticResource DangerButtonStyle}" />
                <Button Content="↻ Оновити" Command="{Binding LoadCommand}"
                        Style="{StaticResource GhostButtonStyle}" />
                <Border Width="1" Background="{StaticResource BorderBrush}" Margin="8,4" />
                <CheckBox Content="Показувати неактивні" IsChecked="{Binding IncludeInactive}"
                          VerticalAlignment="Center" Margin="8,0,0,0" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource ErrorBannerStyle}"
                Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{StaticResource ErrorHoverBrush}"
                       TextWrapping="Wrap" />
        </Border>

        <Border Grid.Row="3" Style="{StaticResource CardBorderStyle}">
            <TreeView ItemsSource="{Binding Tree}" SelectedItemChanged="OnTreeSelectionChanged"
                      BorderThickness="0" Background="Transparent">
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal" Margin="0,3">
                            <TextBlock Text="{Binding Name}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" />
                            <Border Margin="10,0,0,0" Padding="8,2" CornerRadius="6"
                                    Background="{StaticResource AccentSoftBrush}">
                                <TextBlock Text="{Binding Kind, Converter={StaticResource TxKind}}"
                                           Foreground="{StaticResource AccentHoverBrush}"
                                           FontSize="11" FontWeight="SemiBold" />
                            </Border>
                        </StackPanel>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Border>
    </Grid>
</UserControl>
