<UserControl x:Class="PWSV.Client.Views.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PWSV.Client.Converters">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Border Style="{StaticResource CardBorderStyle}"
                Width="460" Padding="32,32,32,28"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Effect="{StaticResource ShadowLarge}">
            <StackPanel>
                <Border Width="56" Height="56"
                        Background="{StaticResource PrimarySoftBrush}"
                        CornerRadius="14"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,16">
                    <TextBlock Text="🔐" FontSize="28"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>

                <TextBlock Text="Створіть обліковий запис"
                           Style="{StaticResource HeadingTextStyle}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Реєстрація доступна лише один раз (перший користувач)"
                           Style="{StaticResource SubtitleTextStyle}"
                           HorizontalAlignment="Center" TextAlignment="Center" />

                <Border Style="{StaticResource ErrorBannerStyle}"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource ErrorHoverBrush}"
                               TextWrapping="Wrap" />
                </Border>

                <TextBlock Text="Ім'я користувача (3-64 символи)" Style="{StaticResource LabelTextStyle}" />
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" TabIndex="0" />

                <TextBlock Text="Пароль (мін. 8, верх+низ регістр, цифра)" Style="{StaticResource LabelTextStyle}" />
                <PasswordBox x:Name="PasswordBox" PasswordChar="•" TabIndex="1"
                             PasswordChanged="PasswordBox_OnPasswordChanged" />

                <TextBlock Text="Підтвердження пароля" Style="{StaticResource LabelTextStyle}" />
                <PasswordBox x:Name="ConfirmPasswordBox" PasswordChar="•" TabIndex="2"
                             PasswordChanged="ConfirmPasswordBox_OnPasswordChanged" />

                <TextBlock Text="Мастер-пароль (для шифрування чутливих полів)" Style="{StaticResource LabelTextStyle}" />
                <PasswordBox x:Name="MasterPasswordBox" PasswordChar="•" TabIndex="3"
                             PasswordChanged="MasterPasswordBox_OnPasswordChanged" />

                <TextBlock Text="Підтвердження мастер-пароля" Style="{StaticResource LabelTextStyle}" />
                <PasswordBox x:Name="ConfirmMasterPasswordBox" PasswordChar="•" TabIndex="4"
                             PasswordChanged="ConfirmMasterPasswordBox_OnPasswordChanged" />

                <Grid Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Назад до входу"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding GoToLoginCommand}"
                            Margin="0,0,4,0" TabIndex="6" />
                    <Button Grid.Column="1" Content="Зареєструватись"
                            Command="{Binding RegisterCommand}" IsDefault="True"
                            Margin="4,0,0,0" TabIndex="5" />
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
