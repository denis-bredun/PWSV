<UserControl x:Class="PWSV.Client.Views.Transactions.TransactionsListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PWSV.Client.Converters">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:MoneyFormatConverter x:Key="MoneyFmt" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Транзакції" Style="{StaticResource HeadingTextStyle}" />
            <TextBlock Text="Доходи, витрати та перекази між рахунками"
                       Style="{StaticResource SubtitleTextStyle}" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource ToolbarBorderStyle}">
            <StackPanel Orientation="Horizontal">
                <Button Content="+ Дохід" Command="{Binding AddIncomeCommand}" />
                <Button Content="− Витрата" Command="{Binding AddExpenseCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" />
                <Button Content="⇄ Переказ" Command="{Binding AddTransferCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" />
                <Button Content="Видалити" Command="{Binding DeleteCommand}"
                        Style="{StaticResource DangerButtonStyle}" />
                <Button Content="↻ Оновити" Command="{Binding LoadCommand}"
                        Style="{StaticResource GhostButtonStyle}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource ErrorBannerStyle}"
                Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{StaticResource ErrorHoverBrush}"
                       TextWrapping="Wrap" />
        </Border>

        <Border Grid.Row="3" Style="{StaticResource CardBorderStyle}" Padding="0">
            <DataGrid ItemsSource="{Binding Transactions}"
                      SelectedItem="{Binding SelectedTransaction}"
                      BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ДАТА" Binding="{Binding OccurredAt, StringFormat=\{0:yyyy-MM-dd HH:mm\}}" Width="160" />
                    <DataGridTextColumn Header="ТИП" Binding="{Binding Kind, Converter={StaticResource TxKind}}" Width="100" />
                    <DataGridTextColumn Header="РАХУНОК" Binding="{Binding AccountName}" Width="200" />
                    <DataGridTextColumn Header="КАТЕГОРІЯ" Binding="{Binding CategoryName}" Width="200" />
                    <DataGridTextColumn Header="СУМА" Binding="{Binding Amount, Converter={StaticResource MoneyFmt}}" Width="140">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="HorizontalAlignment" Value="Right" />
                                <Setter Property="Margin" Value="0,0,12,0" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="КОНТРАГЕНТ" Binding="{Binding Counterparty}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="4" Background="{StaticResource SurfaceAltBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="8" Padding="14,8" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Всього записів:"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding TotalCount}"
                           Foreground="{StaticResource PrimaryBrush}"
                           FontWeight="SemiBold" Margin="6,0,0,0"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
