<UserControl x:Class="PWSV.Client.Views.ExchangeRates.ExchangeRatesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PWSV.Client.Converters">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Курси валют" Style="{StaticResource HeadingTextStyle}" />
            <TextBlock Text="Історія курсів обміну між валютами"
                       Style="{StaticResource SubtitleTextStyle}" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource ErrorBannerStyle}"
                Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{StaticResource ErrorHoverBrush}"
                       TextWrapping="Wrap" />
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" Padding="16" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Зафіксувати курс" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="0,0,0,12" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="База" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" Margin="0,0,6,0" />
                    <ComboBox Grid.Column="1" Width="85" Margin="0,0,12,0"
                              VerticalAlignment="Center"
                              ItemsSource="{Binding Currencies}"
                              SelectedItem="{Binding NewBaseCurrency}" DisplayMemberPath="Code" />
                    <TextBlock Grid.Column="2" Text="Котирування" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" Margin="0,0,6,0" />
                    <ComboBox Grid.Column="3" Width="85" Margin="0,0,12,0"
                              VerticalAlignment="Center"
                              ItemsSource="{Binding Currencies}"
                              SelectedItem="{Binding NewQuoteCurrency}" DisplayMemberPath="Code" />
                    <TextBlock Grid.Column="4" Text="Курс" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" Margin="0,0,6,0" />
                    <TextBox Grid.Column="5" Width="130" Margin="0,0,12,0"
                             VerticalAlignment="Center"
                             Text="{Binding NewRateInput, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Grid.Column="6" Text="Дата" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" Margin="0,0,6,0" />
                    <DatePicker Grid.Column="7" Width="180" Margin="0,0,16,0"
                                VerticalAlignment="Center"
                                SelectedDate="{Binding NewEffectiveDate}" />
                    <Button Grid.Column="9" Content="+ Додати" Command="{Binding AddCommand}" />
                    <Button Grid.Column="10" Content="↻ Оновити" Command="{Binding LoadCommand}"
                            Style="{StaticResource GhostButtonStyle}" />
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource CardBorderStyle}" Padding="0">
            <DataGrid ItemsSource="{Binding Rates}" BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ДАТА" Binding="{Binding EffectiveDate, StringFormat=\{0:yyyy-MM-dd\}}" Width="140" />
                    <DataGridTextColumn Header="БАЗА" Binding="{Binding BaseCurrencyCode}" Width="100" />
                    <DataGridTextColumn Header="КОТИРУВАННЯ" Binding="{Binding QuoteCurrencyCode}" Width="140" />
                    <DataGridTextColumn Header="КУРС" Binding="{Binding Rate}" Width="180">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="ВНЕСЕНО" Binding="{Binding CreatedAt, StringFormat=\{0:yyyy-MM-dd HH:mm\}}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
