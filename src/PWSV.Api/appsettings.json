{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=PWSV;Trusted_Connection=True;Encrypt=False;MultipleActiveResultSets=True"
  },
  "Jwt": {
    "Issuer": "PWSV",
    "Audience": "PWSV.Client",
    "ExpirationHours": 8
  },
  "Crypto": {
    "Pbkdf2Iterations": 100000,
    "KeyLengthBytes": 32
  },
  "Cors": {
    "AllowedOrigins": [ "https://localhost", "http://localhost" ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/pwsv-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "fileSizeLimitBytes": 31457280,
          "rollOnFileSizeLimit": true
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "AllowedHosts": "*"
}
